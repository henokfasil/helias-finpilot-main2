# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite:///./finpilot.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/finpilot

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
UPLOAD_DIR=./uploads

# ── Company Seed ──────────────────────────────────────────────────────────────
DEFAULT_COMPANY_NAME=Helias AI and Analytics
DEFAULT_COMPANY_CURRENCY=ETB
DEFAULT_ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_USER_ID_HERE
