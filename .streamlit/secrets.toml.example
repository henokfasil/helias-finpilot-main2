# Streamlit Cloud Secrets template
# DO NOT commit secrets.toml — only commit this example file
# In Streamlit Cloud: go to App Settings → Secrets → paste the real values
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres"
APP_ENV = "production"
APP_LOG_LEVEL = "INFO"
UPLOAD_DIR = "./uploads"
DEFAULT_COMPANY_NAME = "Helias AI and Analytics"
DEFAULT_COMPANY_CURRENCY = "ETB"
DEFAULT_ADMIN_TELEGRAM_ID = "442192616"
